# Database Configuration
DATABASE_HOST=database
DATABASE_PORT=5432
DATABASE_NAME=project_forge
DATABASE_USERNAME=forge
DATABASE_PASSWORD=forge
DATABASE_SSL=false

# PostgreSQL container init (required by postgres:16-alpine image)
POSTGRES_USER=forge
POSTGRES_PASSWORD=forge
POSTGRES_DB=project_forge

# App / backend
NODE_ENV=development
PORT=1337
DOMAIN=localhost
APP_URL=http://localhost:1337

# Strapi secrets: replace all values before any shared/prod deployment
APP_KEYS=replace-me-1,replace-me-2
API_TOKEN_SALT=replace-me
ADMIN_JWT_SECRET=replace-me
TRANSFER_TOKEN_SALT=replace-me
JWT_SECRET=replace-me
ENCRYPTION_KEY=replace-me

# Frontend
VITE_API_URL=http://localhost:1337

# ---- Project Forge engine (real AI + delivery) ----
# Providers: codex | gemini | openai | anthropic | custom-cli | factory-droid
LLM_PROVIDER=codex
CODEGEN_PROVIDER=codex

# Codex CLI provider
CODEX_COMMAND=codex
CODEX_MODEL=
CODEX_ANALYSIS_MODEL=
CODEX_CODEGEN_MODEL=
CODEX_SANDBOX=read-only
CODEX_TIMEOUT_MS=300000

# Gemini provider
GEMINI_API_KEY=
GEMINI_ANALYSIS_MODEL=gemini-2.0-flash
CODEGEN_MODEL=gemini-1.5-pro

# OpenAI-compatible provider
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-4o-mini
OPENAI_ANALYSIS_MODEL=gpt-4o-mini
OPENAI_CODEGEN_MODEL=gpt-4o

# Anthropic provider
ANTHROPIC_API_KEY=

# GitHub repository generation
GITHUB_PAT=
GITHUB_TOKEN=
GITHUB_OWNER=

# Generated project/deploy settings
FORGE_BUILD_ROOT=/forge-builds
FORGE_BUILD_DOMAIN=localhost
FORGE_DEPLOY_ENABLED=0

# Development-only fallback. Keep 0 for real submissions/demos.
MOCK_MODE=0

# Optional Telegram bot
TELEGRAM_TOKEN=
ALLOWED_USERS=
STRAPI_URL=http://backend:1337
