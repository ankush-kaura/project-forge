{
  "kind": "collectionType",
  "collectionName": "repos",
  "info": {
    "singularName": "repo",
    "pluralName": "repos",
    "displayName": "Repo"
  },
  "options": { "draftAndPublish": false },
  "attributes": {
    "idea": { "type": "relation", "relation": "oneToOne", "target": "api::idea.idea" },
    "repo_url": { "type": "string" },
    "repo_name": { "type": "string" },
    "visibility": { "type": "enumeration", "enum": ["public", "private"], "default": "private" },
    "generated_files": { "type": "json" },
    "github_created": { "type": "boolean", "default": false }
  }
}
